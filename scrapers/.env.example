SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Triggers a Vercel rebuild after new records are inserted
# Create at: vercel.com → Project Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/your-hook-id

# OneSignal push notifications
# Create app at: onesignal.com → Settings → Keys & IDs
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Facebook auto-post (optional — skip silently if not set)
# Generate at: developers.facebook.com → Graph API Explorer
# Token needs: pages_manage_posts, pages_read_engagement
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token
